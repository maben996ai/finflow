# =============================================
# 数据库
# =============================================
DATABASE_URL=postgresql+asyncpg://finflow:finflow@postgres:5432/finflow

# 生产环境单独配置（docker-compose.prod.yml 使用）
POSTGRES_USER=finflow
POSTGRES_PASSWORD=finflow
POSTGRES_DB=finflow

# =============================================
# Redis
# =============================================
REDIS_URL=redis://redis:6379/0

# =============================================
# JWT 认证
# =============================================
# 生产环境请替换为随机长字符串，例如：openssl rand -hex 32
SECRET_KEY=change-me-in-production
# 30天
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# =============================================
# Nginx（生产网关）
# =============================================
# 默认使用 nginx.http.conf，避免在证书未准备好时启动失败
# 准备好证书后改为 nginx.https.conf
NGINX_CONF_FILE=nginx.http.conf

# =============================================
# YouTube Data API v3
# =============================================
# 在 Google Cloud Console 申请，免费配额每日 10,000 units
YOUTUBE_API_KEY=your-google-api-key

# =============================================
# B站（可选）
# =============================================
# 一期公开 API 无需 Cookie，留空即可
# 若后续部分接口需要登录，在此填写浏览器 Cookie 中的 SESSDATA 字段
BILIBILI_SESSDATA=
