# =============================================
# 数据库
# =============================================
DATABASE_URL=postgresql+asyncpg://trendradar:trendradar@postgres:5432/trendradar

# 生产环境单独配置（docker-compose.prod.yml 使用）
POSTGRES_USER=trendradar
POSTGRES_PASSWORD=trendradar
POSTGRES_DB=trendradar

# =============================================
# Redis
# =============================================
REDIS_URL=redis://redis:6379/0

# =============================================
# JWT 认证
# =============================================
# 生产环境请替换为随机长字符串，例如：openssl rand -hex 32
SECRET_KEY=change-me-in-production
# 30天
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# =============================================
# 开发默认账号（本地可选）
# =============================================
# 默认开发邮箱固定为 maben996@gmail.com。
# 若设置 DEV_ACCOUNT_PASSWORD，后端启动时会在本地数据库中自动创建该账号（若尚不存在）。
DEV_ACCOUNT_EMAIL=maben996@gmail.com
DEV_ACCOUNT_DISPLAY_NAME=maben996
DEV_ACCOUNT_PASSWORD=

# =============================================
# Nginx（生产网关）
# =============================================
# 默认使用 nginx.http.conf，避免在证书未准备好时启动失败
# 准备好证书后改为 nginx.https.conf
NGINX_CONF_FILE=nginx.http.conf

# =============================================
# YouTube Data API v3
# =============================================
# 在 Google Cloud Console 申请，免费配额每日 10,000 units
YOUTUBE_API_KEY=your-google-api-key

# =============================================
# B站（可选）
# =============================================
# 一期公开 API 无需 Cookie，留空即可
# 若后续部分接口需要登录，在此填写浏览器 Cookie 中的 SESSDATA 字段
BILIBILI_SESSDATA=

# =============================================
# 飞书自建应用（用于图片上传，卡片通知中嵌入封面）
# =============================================
# 在飞书开放平台创建自建应用后获取，留空则通知中封面回退为链接
FEISHU_APP_ID=
FEISHU_APP_SECRET=
